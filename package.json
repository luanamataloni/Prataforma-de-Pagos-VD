{
  "name": "pagina-de-pagos",
  "version": "1.0.0",
  "description": "Sistema de gestion de pagos - Backend Express + Frontend React (proyecto unificado)",
  "private": true,
  "scripts": {
    "//-- 1: LEVANTA BACK Y FRONT JUNTOS (comando principal) --": "",
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"magenta,cyan\" \"npm run dev:back\" \"npm run dev:front\"",
    "//-- 2: COMANDOS INDIVIDUALES --": "",
    "dev:back": "nodemon backend/server.js",
    "dev:front": "vite frontend --host",
    "//-- 3: PRODUCCION --": "",
    "start": "node backend/server.js",
    "build": "vite build frontend",
    "preview": "vite preview frontend"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.400.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "puppeteer": "^24.9.0",
    "puppeteer": "^25.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "vite": "^5.3.1"
  }
}
